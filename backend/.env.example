PORT=5001
JWT_SECRET=change-me-before-production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# SQLite configuration
# For Render with a persistent disk, use something like /var/data/database.sqlite
# For Railway, point this at a mounted volume path or move to an external database.
DATABASE_PATH=./database.sqlite
ENABLE_DB_BACKUPS=false
SEED_DEFAULT_USERS=false

# Staff security codes
ADMIN_SECURITY_CODE=CP-ADMIN-2468
CASHIER_SECURITY_CODE=CP-CASH-1357

# SMTP configuration for real forgot-password email delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
MAIL_FROM="Charlie PC Store <your-email@example.com>"
