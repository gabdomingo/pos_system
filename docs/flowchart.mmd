flowchart LR
    subgraph Presentation["Presentation Layer"]
        Web["Web App\nCustomer storefront\nCashier POS\nAdmin dashboard, products, sales"]
        Mobile["Mobile App\nCustomer shop, cart, profile\nCashier counter, payment, profile\nAdmin dashboard, products, sales"]
    end

    subgraph Services["Application / Service Layer"]
        API["Express REST API"]
        Auth["Auth Service\n/api/login, /api/register, /api/me"]
        Product["Product Service\n/products, /products/search"]
        Sale["Sales and Checkout Service\n/sales, /sales/:id"]
        Report["Reporting Service\n/reports/dashboard"]
        Ref["Reference Data Service\n/reference/ph-addresses"]
    end

    subgraph Data["Data Layer"]
        DB[("SQLite Database")]
        Addr["PH Address Dataset"]
        Backup["Database Backup"]
    end

    Web <--> |HTTPS + JSON| API
    Mobile <--> |HTTPS + JSON| API

    API --> Auth
    API --> Product
    API --> Sale
    API --> Report
    API --> Ref

    Product <--> DB
    Sale <--> DB
    Report <--> DB
    Auth <--> DB
    Ref <--> Addr
    DB --> Backup
